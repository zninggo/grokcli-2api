# Required — YesCaptcha (Cloudflare Turnstile solver)
YESCAPTCHA_API_KEY=

# Required when using default email backend (-e tempmail)
TEMPMAIL_API_KEY=

# Optional — Cloudflare D1 alias mailbox (-e cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DB_ID=
# Comma-separated domains you control (must match your D1 mail schema)
ALIAS_MAIL_DOMAINS=mail.example.com
# ALIAS_EXTRA_DOMAINS=

# Optional — where to write CLIProxyAPI-compatible auth JSON
# Default: ./cliproxyapi_auth
# CLIPROXYAPI_AUTH_DIR=/path/to/CLIProxyAPI/data/auth

# Optional HTTP(S) proxy
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
